// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  nombre        String
  rut           String    @unique
  edad          Int
  telefono      String
  email         String    @unique
  comuna        String
  puntos        Int       @default(0)
  club          String?
  esSocioCDI    Boolean   @default(false)
  examenesDone  Int       @default(0)
  status        String    @default("PRE_CALENTAMIENTO") // PRE_CALENTAMIENTO, EN_JUEGO, BANEADO
  role          String    @default("USER")              // USER, ADMIN
  badges        Badge[]
  operativos    Operativo[] @relation("UserOperativos")
  photos        Photo[]
  ratings       Rating[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Club {
  id        String   @id @default(cuid())
  nombre    String   @unique
  puntos    Int      @default(0)
  miembros  Int      @default(0)
  logo      String?
}

model Operativo {
  id          String   @id @default(cuid())
  fecha       String
  hora        String
  lugar       String
  direccion   String
  imagen      String
  cupos       Int      @default(50)
  usuarios    User[]   @relation("UserOperativos")
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String
  color       String
  users       User[]
}

model Photo {
  id          String   @id @default(cuid())
  url         String
  titulo      String?
  descripcion String?
  userId      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Song {
  id          String   @id @default(cuid())
  title       String
  artist      String
  audioUrl    String
  coverUrl    String?
  ratings     Rating[]
  createdAt   DateTime @default(now())
}

model Rating {
  id        String   @id @default(cuid())
  stars     Int
  userId    String
  songId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, songId])
}
